{
  "name": "design-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "vitest run --project=storybook",
    "test:a11y": "pa11y-ci",
    "test:a11y:report": "pa11y-ci --reporter pa11y-ci-reporter-html",
    "test:html": "html-validate \"src/components/**/*.ts\"",
    "share": "npx localtunnel --port 6006"
  },
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/blocks": "^8.6.14",
    "@storybook/web-components-vite": "^10.3.4",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "axe-core": "^4.11.2",
    "html-validate": "^10.11.3",
    "pa11y-ci": "^4.1.0",
    "pa11y-ci-reporter-html": "^8.1.1",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0"
  }
}
